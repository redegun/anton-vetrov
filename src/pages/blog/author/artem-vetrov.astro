---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import PersonSchema from '../../../components/PersonSchema.astro';
import { getCollection } from 'astro:content';
import { categoryToSlug } from '../../../utils/slugify';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft;
});

const posts = allPosts
  .filter(p => p.data.author === 'Артём Ветров')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title="Артём Ветров — автор блога | Антон Ветров" description="Статьи Артёма Ветрова о веб-разработке, MODX, AI и автоматизации бизнеса.">
  <PersonSchema
    name="Артём Ветров"
    url={Astro.url.href}
    jobTitle="Веб-разработчик"
  />

  <section class="container" style="padding-top: var(--space-12); padding-bottom: var(--space-20);">
    <Breadcrumbs items={[
      { label: "Главная", href: "/" },
      { label: "Блог", href: "/blog/" },
      { label: "Артём Ветров" }
    ]} />

    <div class="author-page-header">
      <div class="author-page-avatar">АВ</div>
      <div class="author-page-info">
        <h1>Артём Ветров</h1>
        <p class="author-page-bio">Веб-разработчик с 20-летним опытом. Создаю сайты на MODX, внедряю AI-решения для бизнеса, занимаюсь SEO-продвижением. Пишу о технологиях, автоматизации и современной веб-разработке.</p>
        <div class="author-page-stats">
          <span>{posts.length} {posts.length === 1 ? 'статья' : posts.length < 5 ? 'статьи' : 'статей'}</span>
        </div>
      </div>
    </div>

    <h2 class="author-posts-title">Статьи автора</h2>

    <div class="blog-grid">
      {posts.map((post) => (
        <a href={`${base}blog/${post.slug}/`} class="blog-card">
          {post.data.heroImage && (
            <div class="blog-card-image">
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" decoding="async" />
            </div>
          )}
          <div class="blog-card-content">
            <div class="blog-meta">
              <span>{formatDate(post.data.pubDate)}</span>
              <span class="separator"></span>
              <span class="category-badge">{post.data.category}</span>
            </div>
            <h3 class="blog-card-title">{post.data.title}</h3>
            <p class="blog-card-desc">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .author-page-header {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    margin: var(--space-8) 0 var(--space-12);
    padding: var(--space-8);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .author-page-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--gradient-accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: white;
  }

  .author-page-info h1 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-2);
  }

  .author-page-bio {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
    line-height: 1.6;
  }

  .author-page-stats {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .author-posts-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 640px) {
    .author-page-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
