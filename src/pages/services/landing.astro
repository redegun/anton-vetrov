    { icon: "🔧", title: "Интеграция с CRM", text: "Подключение форм к AmoCRM, Битрикс24 или вашей CRM-системе." }
  ]}
  steps_title="Как я работаю"
  steps={[
    { number: 1, title: "Бриф и ТЗ", duration: "1–2 дня", text: "Обсуждаем задачу, целевую аудиторию, конкурентов. Формирую техническое задание." },
